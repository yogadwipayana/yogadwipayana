# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/supabase/.temp

# next.js
/.next/
/out/

# production
/build
/ai
/.kilo
/.vscode
/.devin

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log

# env files (can opt-in for committing if needed)
.env*
.mcp.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated images (runtime artifacts)
/public/generated-images/
